# ============================================
# Network Configuration
# ============================================
# The IP address to bind Docker ports to.
# Use 127.0.0.1 for local development (only accessible from this machine).
# Use 0.0.0.0 or your public IP for production access.
BIND_IP=127.0.0.1

# The port the server will be accessible on from outside
# Development: 3000, Production: 80
SERVER_PORT=3000

# ============================================
# Application Configuration
# ============================================
# Environment: development, production
ENVIRONMENT=production

# Public URL of the application (used in emails and links)
# Development: http://localhost:3000, Production: https://slatehub.com
APP_URL=http://localhost:3000

# Logging Level: trace, debug, info, warn, error
RUST_LOG=info,slatehub=debug,tower_http=debug
# Log Format: pretty, json, compact
LOG_FORMAT=pretty

# ============================================
# Database Configuration (SurrealDB)
# ============================================
DB_USER=root
DB_PASS=root
DB_NAMESPACE=slatehub
DB_NAME=main

# Internal hostname/port (usually doesn't need changing if using Docker)
DB_HOST=surrealdb
DB_PORT=8000
# Optional: Full connection URL (overrides host/port if set)
# DATABASE_URL=ws://surrealdb:8000

# ============================================
# File Storage Configuration (S3-compatible)
# ============================================
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password
S3_BUCKET=slatehub
S3_REGION=us-east-1

# Internal endpoint for the app to reach the S3-compatible store (RustFS)
S3_ENDPOINT=http://rustfs:9000

# ============================================
# Security Secrets (MUST CHANGE IN PRODUCTION)
# ============================================
JWT_SECRET=change_me_please
SESSION_SECRET=change_me_please

# ============================================
# Email Configuration (Mailjet)
# ============================================
# Required for sending emails (password reset, invites, etc.)
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_API_SECRET=your_mailjet_api_secret
MAILJET_FROM_EMAIL=noreply@slatehub.com
MAILJET_FROM_NAME=SlateHub

# Where feedback form submissions are emailed (falls back to MAILJET_FROM_EMAIL)
FEEDBACK_RECIPIENT_EMAIL=feedback@slatehub.com

# ============================================
# TMDB (The Movie Database) API
# ============================================
# Free API key from https://www.themoviedb.org/settings/api
# Used for importing film/TV credits into user profiles
TMDB_API_KEY=

# ============================================
# Search & Embedding Configuration
# ============================================
# Scoring weights for text-match fields in search results.
# Higher values rank matches on that field more prominently.
SEARCH_WEIGHT_NAME=50
SEARCH_WEIGHT_HEADLINE=20
SEARCH_WEIGHT_LOCATION=10

# Multiplier applied to vector (semantic) similarity score.
# Controls how much embedding similarity influences ranking.
SEARCH_WEIGHT_VECTOR=50

# Minimum cosine similarity for a vector match to pass the WHERE gate.
# Higher = stricter (fewer false positives), lower = more recall.
# Recommended range: 0.65-0.85 for domain-specific platforms.
SEARCH_VECTOR_THRESHOLD=0.75

# MCP-specific overrides — LLM consumers benefit from more results at lower thresholds
# since the LLM can filter/rank with its own intelligence. These default lower than web.
# MCP_SEARCH_WEIGHT_NAME=50
# MCP_SEARCH_WEIGHT_HEADLINE=20
# MCP_SEARCH_WEIGHT_LOCATION=10
# MCP_SEARCH_WEIGHT_VECTOR=50
MCP_SEARCH_VECTOR_THRESHOLD=0.55

# ============================================
# WhatsApp Bot Configuration
# ============================================
# Phone number for pairing (country code + number, no + sign)
# Example: 15551234567 for US +1 (555) 123-4567
WHATSAPP_PHONE_NUMBER=
# Device name shown in WhatsApp Linked Devices list
WHATSAPP_DEVICE_NAME=SlateHub Bot
