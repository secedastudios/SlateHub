{
  "manifest_version": 3,
  "name": "SlatHub IMDb Import",
  "version": "1.0.0",
  "description": "Import your IMDb filmography into your SlatHub profile",
  "permissions": ["activeTab", "storage", "cookies"],
  "host_permissions": [
    "https://www.imdb.com/*",
    "https://slatehub.com/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.imdb.com/name/nm*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
